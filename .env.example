# ==============================================================================
# VOCALBRIDGE SALES AI - ENVIRONMENT CONFIGURATION
# ==============================================================================

# --- GOOGLE GEMINI CONFIG ---
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# --- FIREBASE CONFIG ---
# To get these values:
# 1. Go to Firebase Console: https://console.firebase.google.com/
# 2. Select your project.
# 3. Go to Project Settings (cog icon) > General.
# 4. Scroll down to "Your apps" and select the Web App (</> icon).
# 5. Copy the values from the `firebaseConfig` object.

VITE_FIREBASE_API_KEY="your_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your_project_id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_project_id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id"
VITE_FIREBASE_APP_ID="your_app_id"

# --- FIRESTORE DATABASE CONFIG ---
# If you are using a specific database ID (common in AI Studio environments), 
# provide it here. Otherwise, use "(default)".
# Found in: Firebase Console > Firestore Database > Data tab (check the dropdown at the top).
VITE_FIREBASE_DATABASE_ID="(default)"

# --- TWILIO CONFIG ---
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"
# For local dev: run `npx ngrok http 3000` and paste the https URL here
# For production: your deployed server URL (e.g. Render)
PUBLIC_SERVER_URL="https://your-app.onrender.com"

# --- OPTIONAL: SERVER CONFIG ---
PORT=3000
NODE_ENV="development"
